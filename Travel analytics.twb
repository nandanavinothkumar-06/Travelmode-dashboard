    <worksheet name='Sheet 5'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontsize='12'>Travel Efficiency Score by Mode</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='TravelMode' name='federated.1pesh3t0rrxqnf149vyxy1d7t8tk' />
          </datasources>
          <datasource-dependencies datasource='federated.1pesh3t0rrxqnf149vyxy1d7t8tk'>
            <column caption='Efficiency Score' datatype='real' name='[Calculation_1508260589981696]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([travel]) / SUM([gcost])' />
            </column>
            <column caption='Gcost' datatype='integer' name='[gcost]' role='measure' type='quantitative' />
            <column caption='Mode' datatype='string' name='[mode]' role='dimension' type='nominal' />
            <column-instance column='[mode]' derivation='None' name='[none:mode:nk]' pivot='key' type='nominal' />
